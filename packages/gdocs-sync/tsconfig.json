{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": [
      "vitest/globals"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src",
    "test",
    "scripts"
  ]
}