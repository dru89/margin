{
  "name": "@dru89/gdocs-sync",
  "version": "0.3.0",
  "description": "Markdown <-> Google Docs sync engine and CLI: incremental push, high-fidelity fetch, comments-safe updates, tabs, images, callouts. Built against the dru89/doc-tools scenario catalog.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "auth": "node src/auth.ts",
    "smoke": "node scripts/smoke.ts",
    "rt1": "node scripts/rt1.ts",
    "test:live": "vitest run --config vitest.live.config.ts",
    "gdocs": "node src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.20.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "mdast-util-from-markdown": "^2.0.1",
    "mdast-util-gfm": "^3.0.0",
    "micromark-extension-gfm": "^3.0.0"
  },
  "bin": {
    "gdocs": "dist/cli.js"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dru89/margin.git",
    "directory": "packages/gdocs-sync"
  },
  "keywords": [
    "google-docs",
    "markdown",
    "sync",
    "drive",
    "cli"
  ]
}
